@page "/"
@rendermode InteractiveServer
@using Tellurian.Trains.WiFreds.Resources
@using Tellurian.Trains.WiFreds.Server
@inject WiFredDiscoveryService DiscoveryService
@implements IDisposable

<PageTitle>@Messages.ConnectedWiFREDs</PageTitle>

<h2>@Messages.ConnectedWiFREDs</h2>

@if (_devices.Count == 0)
{
    <p class="no-devices">@Messages.NoDevicesConnected</p>
}
else
{
    <table class="device-table">
        <thead>
            <tr>
                <th>@Messages.Name</th>
                <th>@Messages.IPAddress</th>
                <th>@Messages.Firmware</th>
                <th>@Messages.Battery</th>
                @for (var i = 1; i <= WiFredDevice.LocoSlotCount; i++)
                {
                    <th>@string.Format(Messages.LocoSlot, i)</th>
                }
                <th>@Messages.LastSeen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var device in _devices)
            {
                var slots = device.LocoSlots;
                <tr>
                    <td>@(device.Name ?? Messages.Unnamed)</td>
                    <td>@device.Address</td>
                    <td>@(device.FirmwareVersion ?? "-")</td>
                    <td>@(device.BatteryVoltage ?? "-")</td>
                    @foreach (var slot in slots)
                    {
                        <td class="loco-cell">
                            @if (IsEditing(device, slot.Slot))
                            {
                                <div class="loco-edit">
                                    <input type="number" min="0" max="9999" @bind="_editAddress" @bind:event="oninput" />
                                    <button class="save-btn" @onclick="() => SaveLocoAddress(device, slot.Slot)">@Messages.Save</button>
                                    <button class="cancel-btn" @onclick="CancelEdit">&times;</button>
                                </div>
                            }
                            else
                            {
                                <span class="loco-value" @onclick="() => StartEdit(device, slot)">
                                    @(slot.Address > 0 ? slot.Address : "-")
                                </span>
                            }
                        </td>
                    }
                    <td>@device.LastSeen.LocalDateTime.ToString("HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </table>
}

<p class="last-updated">@Messages.LastUpdated: @_lastUpdated.ToString("HH:mm:ss")</p>

@if (_conflicts.Count > 0)
{
    <h3>@Messages.LocoAddressConflicts</h3>
    <table class="conflict-table">
        <thead>
            <tr>
                <th>@Messages.LocoAddress</th>
                <th>@Messages.ConflictingDevices</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var conflict in _conflicts)
            {
                <tr>
                    <td>@conflict.Address</td>
                    <td>@string.Join(", ", conflict.Devices.Select(d => d.Name ?? d.Address.ToString()))</td>
                </tr>
            }
        </tbody>
    </table>
}

<style>
    h2, h3 {
        color: #eee;
        margin-bottom: 12px;
    }

    .no-devices {
        color: #888;
        font-style: italic;
    }

    .device-table, .conflict-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 24px;
    }

    .device-table th, .device-table td,
    .conflict-table th, .conflict-table td {
        text-align: left;
        padding: 8px 12px;
        border-bottom: 1px solid #333;
    }

    .device-table th, .conflict-table th {
        color: #aaa;
        font-weight: 600;
        border-bottom: 2px solid #555;
    }

    .device-table td, .conflict-table td {
        color: #ddd;
    }

    .conflict-table td {
        color: #f88;
    }

    .last-updated {
        color: #666;
        font-size: 0.85rem;
    }

    .loco-value {
        cursor: pointer;
        padding: 2px 8px;
        border-radius: 4px;
    }

    .loco-value:hover {
        background-color: #444;
    }

    .loco-edit {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .loco-edit input {
        width: 70px;
        padding: 2px 6px;
        background: #333;
        color: #eee;
        border: 1px solid #666;
        border-radius: 4px;
    }

    .save-btn {
        padding: 2px 8px;
        background: #2a7a2a;
        color: #eee;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.85rem;
    }

    .save-btn:hover {
        background: #3a9a3a;
    }

    .cancel-btn {
        padding: 2px 6px;
        background: transparent;
        color: #888;
        border: none;
        cursor: pointer;
        font-size: 1rem;
    }

    .cancel-btn:hover {
        color: #f88;
    }
</style>

@code {
    private IReadOnlyList<WiFredDevice> _devices = [];
    private IReadOnlyList<LocoAddressConflict> _conflicts = [];
    private DateTime _lastUpdated = DateTime.Now;
    private Timer? _refreshTimer;

    private WiFredDevice? _editingDevice;
    private int _editingSlot;
    private int _editAddress;

    protected override void OnInitialized()
    {
        RefreshData();
        _refreshTimer = new Timer(_ => InvokeAsync(() =>
        {
            RefreshData();
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private void RefreshData()
    {
        _devices = DiscoveryService.GetDiscoveredDevices();
        _conflicts = DiscoveryService.GetLocoAddressConflicts();
        _lastUpdated = DateTime.Now;
    }

    private bool IsEditing(WiFredDevice device, int slot) =>
        _editingDevice == device && _editingSlot == slot;

    private void StartEdit(WiFredDevice device, LocoSlot slot)
    {
        _editingDevice = device;
        _editingSlot = slot.Slot;
        _editAddress = slot.Address;
    }

    private void CancelEdit()
    {
        _editingDevice = null;
        _editingSlot = 0;
    }

    private async Task SaveLocoAddress(WiFredDevice device, int slot)
    {
        await DiscoveryService.UpdateLocoAddressAsync(device.Address, slot, _editAddress);
        CancelEdit();
        RefreshData();
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
